---
import { ITEM_CATEGORIES, ITEM_CATEGORY_MAP, ITEMS } from '@/constants/items/item';
import Layout from '@/layouts/Layout.astro';

const searchParams = new URLSearchParams(Astro.url.search);
const name = searchParams.get('name');

let category: string | undefined = undefined;
if (name && name.length > 0) {
  const item = ITEMS.find((item) => item.name.toLowerCase().includes(name.toLowerCase().trim()));
  if (item) {
    category = ITEM_CATEGORY_MAP[item.itemType.toLowerCase() as keyof typeof ITEM_CATEGORY_MAP] || ITEM_CATEGORIES[0];
  }
}

return Astro.redirect(`/items/${category || ITEM_CATEGORIES[0]}${name ? `?name=${name}` : ''}`);
---

<Layout />
