---
import { ItemsPage } from '@/components/pages/ItemsPage';
import { ITEM_CATEGORIES } from '@/constants/items/item';
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return ITEM_CATEGORIES.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
---

<Layout class="mx-auto flex min-h-0 w-full max-w-4xl flex-1 flex-col gap-4 px-4 py-12">
  <ItemsPage category={category} client:only="react" />
</Layout>
